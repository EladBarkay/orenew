# Supabase project config (anon key is public — safe to ship).
# Shared by frontend (Vite, import.meta.env) and backend (build.rs).
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Ed25519 PUBLIC key (SPKI PEM) used by the desktop client to verify the
# server-signed entitlement token offline. Public — safe to ship. The matching
# PRIVATE key is set only as the Edge Function secret ENTITLEMENT_SIGNING_KEY
# (never commit it). Generate a keypair with:
#   openssl genpkey -algorithm ed25519 -out ent_priv.pem
#   openssl pkey -in ent_priv.pem -pubout -out ent_pub.pem
# Paste the public PEM here as one line with literal \n between the lines, e.g.:
#   ENTITLEMENT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMCowBQYD...\n-----END PUBLIC KEY-----"
ENTITLEMENT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nUNCONFIGURED\n-----END PUBLIC KEY-----"
