{
  "build": {
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "MagNet",
    "version": "0.1.0"
  },
  "tauri": {
    "bundle": {
      "identifier": "com.magnet.dev"
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 600,
        "resizable": true,
        "title": "MagNet",
        "width": 800
      }
    ]
  }
}
