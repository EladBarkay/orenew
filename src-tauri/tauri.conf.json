{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Orenew",
  "version": "1.0.0",
  "identifier": "com.orenew.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Orenew",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["orenew"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/EladBarkay/orenew/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgzNDExRUM0OTBFRjg3N0YKUldSL2grK1F4QjVCZzhqb2U3QmE0elo1SmExd2s2NDYvTWJVc2FHZHh2V3JIVzZnM0V5dzFucnAK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
